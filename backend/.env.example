# ===================================
# Go E-Commerce Microservices Config
# ===================================

# --- PostgreSQL (single shared database) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go_ecommerce
DB_SSLMODE=disable

# --- Redis (shared) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=your-super-secret-key-change-in-production

# --- Service Ports ---
# api-gateway:           8080
# user-service:          8081
# product-service:       8082
# cart-service:           8083
# order-service:          8084
# payment-service:        8085
# review-service:         8086
# coupon-service:         8087
# notification-service:   8088
